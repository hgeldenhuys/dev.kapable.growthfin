{
  "name": "@agios/transcript-types",
  "version": "0.1.0",
  "description": "TypeScript types and utilities for Claude Code transcript files",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "type-check": "tsc --noEmit",
    "analyze": "bun run analyze-shapes.ts",
    "test": "bun test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "transcript",
    "types",
    "typescript",
    "jsonl"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
