{
  "name": "@signaldb-live/client",
  "version": "0.1.2",
  "description": "Official JavaScript/TypeScript client for SignalDB - realtime database as a service",
  "author": "SignalDB",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build:esm && bun run build:cjs && bun run build:types",
    "build:esm": "bun build ./src/index.ts --outfile=dist/index.mjs --format=esm --target=browser",
    "build:cjs": "bun build ./src/index.ts --outfile=dist/index.js --format=cjs --target=node",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "signaldb",
    "realtime",
    "database",
    "api",
    "client",
    "sdk",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/signaldb-live/signaldb.git",
    "directory": "packages/js"
  },
  "bugs": {
    "url": "https://github.com/signaldb-live/signaldb/issues"
  },
  "homepage": "https://signaldb.live"
}
