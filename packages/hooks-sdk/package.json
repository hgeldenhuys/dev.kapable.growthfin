{
  "name": "@agios/hooks-sdk",
  "version": "0.1.0",
  "description": "Type-safe TypeScript SDK for Claude Code hooks",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./use-hooks": "./src/use-hooks.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "dev": "bun --watch src/use-hooks.ts",
    "build": "bun run build.ts",
    "build:bundle": "bun run build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "install-hooks": "bun src/install-hooks.ts",
    "uninstall-hooks": "bun src/uninstall-hooks.ts"
  },
  "dependencies": {
    "@agios/transcript-types": "workspace:*",
    "minimatch": "10.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {},
  "engines": {
    "bun": ">=1.0.0"
  }
}
