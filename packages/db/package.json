{
  "name": "@agios/db",
  "version": "0.1.0",
  "description": "Shared database schemas and client for Agios",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "bun run src/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.6",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/bun": "latest",
    "bcryptjs": "3.0.2",
    "bun-types": "1.3.2",
    "drizzle-kit": "^0.31.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
