# =============================================================================
# GrowthFin API — Environment Variables
# =============================================================================
# Copy to .env and fill in values. Variables are grouped by priority:
#   REQUIRED  — API will not start without these
#   CRITICAL  — API starts but core features break without them
#   OPTIONAL  — Enable specific integrations; features degrade gracefully
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED (fatal if missing — API refuses to boot)
# ---------------------------------------------------------------------------

# Auth encryption secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Master encryption key for data-at-rest — generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# CRITICAL (API boots, but warns loudly; core features may break)
# ---------------------------------------------------------------------------

# PostgreSQL connection string
# In production, must NOT reference localhost
DATABASE_URL=postgresql://user:password@localhost:5432/growthfin

# Base URL of this API — used by BetterAuth for callback URLs
# In production, set to public URL (e.g. https://api.yourdomain.com)
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated allowed CORS origins — drives both CORS headers and trustedOrigins
# In production, set to your frontend URL(s)
CORS_ORIGIN=http://localhost:5173

# Trusted origins for BetterAuth (overrides CORS_ORIGIN for auth specifically)
# Only set if auth needs different origins than CORS
# TRUSTED_ORIGINS=https://growthfin.signaldb.app,https://app.signaldb.live

# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# OPTIONAL — AI / LLM
# ---------------------------------------------------------------------------

# OpenAI — used for lead import AI suggestions
OPENAI_API_KEY=

# OpenRouter — used by CRM enrichment service
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — Voice (ElevenLabs)
# Requires all three if any is set
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=

# ---------------------------------------------------------------------------
# OPTIONAL — Telephony (Twilio)
# SID, TOKEN, and PHONE_NUMBER must all be set together
# Get your credentials at: https://console.twilio.com
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# Twilio webhook base URL (production only)
# TWILIO_WEBHOOK_URL=https://api.yourdomain.com/api/v1/crm/webhooks/twilio

# ---------------------------------------------------------------------------
# OPTIONAL — Email (Resend)
# Get your API key at: https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=campaigns@yourdomain.com

# ---------------------------------------------------------------------------
# OPTIONAL — Enrichment
# ---------------------------------------------------------------------------

# Brave Search — web search enrichment
# Get your API key at: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Perplexity — AI-powered research
PERPLEXITY_API_KEY=

# LinkedIn enrichment via RapidAPI
RAPIDAPI_LINKEDIN_KEY=

# Email verification
ZEROBOUNCE_API_KEY=

# Google Maps — address lookup
GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# DEVELOPMENT ONLY
# ---------------------------------------------------------------------------

# Test mode — uses mock adapters instead of real services
TEST_MODE=false
TWILIO_OUTBOUND_TEST_NUMBER=+1234567890
