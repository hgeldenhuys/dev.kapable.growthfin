      if (!query.messageId || !query.contactId) {
        set.status = 400;
        return { error: 'messageId and contactId are required' };
      }

      const preview = await campaignMessageService.previewMessage(
        db,
        query.messageId,
        query.contactId,
        query.workspaceId
      );

      if (!preview) {
        set.status = 404;
        return { error: 'Message or contact not found' };
      }

      return preview;
