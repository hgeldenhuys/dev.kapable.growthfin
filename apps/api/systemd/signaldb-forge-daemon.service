[Unit]
Description=SignalDB Forge Daemon - Claude CLI Process Manager
Documentation=https://signaldb.live/docs/forge
After=network.target postgresql.service signaldb-api.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/opt/signaldb/apps/api

# Load environment variables
EnvironmentFile=/etc/signaldb/api.env
Environment=FORGE_DAEMON_PORT=3015

# Main daemon process
ExecStart=/home/deploy/.bun/bin/bun run src/services/forge-daemon.ts

# Restart policy
Restart=always
RestartSec=5

# Only kill the daemon process itself — CLI scopes survive daemon restarts
KillMode=process
KillSignal=SIGTERM
TimeoutStopSec=15

# Daemon itself is lightweight — CLI processes run in their own systemd scopes
MemoryMax=256M

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/deploy/forge-workspaces /home/sdb_*
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=signaldb-forge-daemon

[Install]
WantedBy=multi-user.target
