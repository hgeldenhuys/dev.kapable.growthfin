    "@google/genai": "1.42.0",
    "@types/bcryptjs": "3.0.0",
    "@types/js-yaml": "4.0.9",
    "@xenova/transformers": "2.17.2",
    "ajv": "^8.12.0",
    "bcryptjs": "3.0.2",
    "better-auth": "1.3.27",
    "chalk": "5.6.2",
    "cron-parser": "5.4.0",
    "drizzle-orm": "^0.44.6",
    "elysia": "^1.4.10",
    "handlebars": "4.7.8",
    "js-yaml": "4.1.0",
    "libphonenumber-js": "1.12.28",
    "marked": "^11.0.0",
